# === LLM (필수) ===
OPENAI_API_KEY=sk-...

# 모델 선택 (선택, 기본: gpt-4.1-mini)
# - gpt-4.1-nano : 가장 저렴/빠름. 정확도 낮음. JSON 파싱 실패 가능.
# - gpt-4.1-mini : 권장. 가성비. reflector/planner 정확도 좋음.
# - gpt-4.1      : 최고 정확도. 비용 ~5배.
# - gpt-4o-mini  : 이전 기본값. 가격은 비슷하지만 4.1-mini가 더 정확.
# OPENAI_MODEL=gpt-4.1-mini

# === 지역/맛집 검색 ===
# 필수: 발급 → https://developers.kakao.com (REST API key)
KAKAO_REST_API_KEY=

# 선택: 발급 → https://developers.naver.com (검색 → 지역)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 선택: 발급 → https://console.cloud.google.com (Places API New)
GOOGLE_PLACES_API_KEY=

# === Phoenix (트레이스, 선택) ===
PHOENIX_COLLECTOR_ENDPOINT=https://phoenix.rheon.kr/api/collect
PHOENIX_API_KEY=
# PHOENIX_PROJECT_NAME=restaurant   # 기본값이 "restaurant"이라 생략 가능
# PHOENIX_DISABLED=1                # 트레이스 끄기
# PHOENIX_DEBUG=1                   # OTel 디버그 로그
